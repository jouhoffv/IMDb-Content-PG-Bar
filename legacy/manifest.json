{
  "manifest_version": 2,
  "name": "BookmarkThat",
  "version": "2.0",
  "description": "Save URLs to bookmarks and manage Firefox container tab unload/reload policies.",
  "icons": {
    "48": "icons/icon.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "bookmarks",
    "tabs",
    "alarms",
    "cookies",
    "browsingData",
    "contextualIdentities",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "applications": {
    "gecko": {
      "id": "bookmarkthat@local"
    }
  }
}
