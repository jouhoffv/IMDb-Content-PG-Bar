{
  "manifest_version": 2,
  "name": "IMDb Content Warning Bar",
  "version": "1.0.0",
  "description": "Shows a thin red bar on IMDb title pages when selected parental guide categories are present.",
  "permissions": [
    "storage",
    "tabs",
    "*://www.imdb.com/title/*",
    "*://m.imdb.com/title/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "imdb-content-warning-bar@example.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "IMDb Content Warning Bar",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.imdb.com/title/*",
        "*://m.imdb.com/title/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
