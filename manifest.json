{
  "manifest_version": 2,
  "name": "IMDb Content Warning Bar",
  "version": "1.2.0",
  "description": "Shows a color-coded Parents Guide bar on IMDb title pages.",
  "author": "Victor",
  "homepage_url": "https://github.com/jouhoffv",
  "icons": {
    "48": "assets/logos/imdb_banner.png",
    "96": "assets/logos/imdb_banner.png",
    "128": "assets/logos/imdb_banner.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "*://www.imdb.com/title/*",
    "*://www.imdb.com/*/title/*",
    "*://m.imdb.com/title/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "imdb-content-warning-bar@example.com",
      "data_collection_permissions": {
        "required": [
          "browsingActivity",
          "websiteContent"
        ]
      },
      "strict_min_version": "140.0"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "IMDb Content Warning Bar",
    "default_icon": {
      "48": "assets/logos/imdb_banner.png"
    },
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.imdb.com/title/*",
        "*://www.imdb.com/*/title/*",
        "*://m.imdb.com/title/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ]
}
